{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Post",
  "description": "Schema for a single Post object from the /posts endpoint",
  "type": "object",
  "required": ["userId", "id", "title", "body"],
  "properties": {
    "userId": {
      "type": "integer",
      "description": "ID of the user who authored the post"
    },
    "id": {
      "type": "integer",
      "description": "Unique identifier of the post"
    },
    "title": {
      "type": "string",
      "description": "Title of the post",
      "minLength": 1
    },
    "body": {
      "type": "string",
      "description": "Body content of the post",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
